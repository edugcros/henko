{
  "name": "ecommerce-app",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "babel": {
    "extends": "./babel.config.cjs"
  },
  "scripts": {
    "dev": "cross-env NODE_ENV=development HOST=henko.local webpack serve --port 3002 --mode development",
    "dev:local": "cross-env NODE_ENV=development HOST=localhost webpack serve --port 3002 --mode development",
    "build": "cross-env NODE_ENV=production webpack --mode production",
    "build:prod": "cross-env NODE_ENV=production webpack --mode production",
    "build:staging": "cross-env NODE_ENV=staging webpack --mode production",
    "preview": "serve -s dist -l 3002",
    "clean": "rimraf dist build",
    "lint": "eslint src/**/*.{js,jsx} --fix",
    "format": "prettier --write src/**/*.{js,jsx,css,scss,json,html}",
    "start": "npm run dev",
    "test": "jest --coverage --watchAll",
    "test:watch": "jest --watchAll",
    "test:ci": "jest --ci",
    "deploy": "npm run clean && npm run build:prod"
  },
  "dependencies": {
    "@emotion/is-prop-valid": "^1.3.1",
    "@emotion/react": "^11.11.1",
    "@emotion/styled": "^11.11.0",
