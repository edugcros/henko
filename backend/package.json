{
  "type": "module",
  "name": "ecommerce",
  "version": "1.0.0",
  "description": "Backend for E-commerce",
  "main": "server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon server.js",
    "start": "cross-env NODE_ENV=production node server.js",
    "start:prod": "cross-env NODE_ENV=production node server.js",
    "start:dev": "cross-env NODE_ENV=development node server.js",
    "check:env:dev": "cross-env NODE_ENV=development node src/scripts/checkEnv.js",
    "check:env:prod": "cross-env NODE_ENV=production node src/scripts/checkEnv.js",
    "migrate:catalog-variants": "cross-env NODE_ENV=development node src/scripts/backfillCatalogVariantTemplates.js",
    "migrate:catalog-variants:prod": "cross-env NODE_ENV=production node src/scripts/backfillCatalogVariantTemplates.js",
    "migrate:ai-agent-secrets": "cross-env NODE_ENV=development node src/scripts/migrateAiAgentSecrets.js",
    "migrate:ai-agent-secrets:apply": "cross-env NODE_ENV=development node src/scripts/migrateAiAgentSecrets.js --apply",
    "migrate:ai-agent-secrets:prod": "cross-env NODE_ENV=production node src/scripts/migrateAiAgentSecrets.js --apply",
    "migrate:tenant-secrets": "cross-env NODE_ENV=development node src/scripts/migrateTenantSecrets.js",
    "migrate:tenant-secrets:apply": "cross-env NODE_ENV=development node src/scripts/migrateTenantSecrets.js --apply",
    "migrate:tenant-secrets:prod": "cross-env NODE_ENV=production node src/scripts/migrateTenantSecrets.js --apply",
    "lint": "eslint . --ext .js",
    "fix": "eslint . --ext .js --fix",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules ./node_modules/jest/bin/jest.js --runInBand"
  },
  "jest": {
    "testTimeout": 30000
  },
  "dependencies": {
    "@google-analytics/data": "^5.2.1",
    "@google-cloud/storage": "^7.21.0",
    "@google/generative-ai": "^0.24.1",
    "axios": "^1.8.4",
    "bcrypt": "^6.0.0",
    "body-parser": "^1.20.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^16.6.1",
    "express": "^4.22.1",
    "express-async-handler": "^1.2.0",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.5.0",
    "express-validator": "^7.2.1",
    "flru": "^1.0.2",
    "googleapis": "^171.4.0",
    "helmet": "^7.2.0",
    "jsonwebtoken": "^9.0.2",
    "logger": "^0.0.1",
    "mercadopago": "^3.1.0",
    "mongodb": "^7.5.0",
    "mongoose": "^6.13.8",
    "morgan": "^1.10.1",
    "multer": "^2.2.0",
    "node-cache": "^5.1.2",
    "nodemailer": "^9.0.1",
    "redis": "^5.11.0",
    "resend": "^4.5.0",
    "sanitize-html": "^2.15.0",
    "sharp": "^0.34.4",
    "slugify": "^1.6.5",
    "uniqid": "^5.4.0",
    "uuid": "^14.0.1",
    "winston": "^3.17.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "@babel/cli": "^7.26.4",
    "@babel/core": "^7.27.1",
    "@babel/eslint-parser": "^7.26.10",
    "@babel/node": "^7.26.0",
    "@babel/plugin-transform-optional-chaining": "^7.29.7",
    "@babel/plugin-transform-private-methods": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.26.10",
    "@babel/preset-env": "^7.27.1",
    "@babel/register": "^7.25.9",
    "@eslint/js": "^9.20.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-jest": "^28.11.0",
    "eslint-plugin-prettier": "^5.2.3",
    "globals": "^15.14.0",
    "jest": "^29.7.0",
    "mongodb-memory-server": "^10.1.4",
    "nodemon": "^3.1.11",
    "prettier": "^3.8.3",
    "process": "^0.11.10",
    "supertest": "^7.1.0"
  }
}
