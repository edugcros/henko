NODE_ENV=production

WATCH_FOLDER=D:/Henko/importar-productos
PROCESSED_FOLDER=D:/Henko/importar-productos/processed
FAILED_FOLDER=D:/Henko/importar-productos/failed

API_BASE_URL=https://api.example.com/api
TENANT_DOMAIN=store.example.com
AGENT_API_KEY=replace-with-a-long-random-secret
ANALYSIS_ENDPOINT=/product-analysis/import
AGENT_HEALTH_ENDPOINT=

AUTO_ANALYZE=true
AUTO_CREATE_PRODUCT=false
AUTO_SAVE_PRODUCT=false
AUTO_PUBLISH_PRODUCT=false

AGENT_CONCURRENCY=2
AGENT_MAX_RETRIES=4
AGENT_RETRY_BASE_MS=1500
AGENT_REQUEST_TIMEOUT_MS=120000
AGENT_MAX_FILE_SIZE_BYTES=10485760
AGENT_LOCK_STALE_MS=120000

AGENT_DEFAULT_SEND_AT=
AGENT_DEFAULT_DELAY_MINUTES=0

PROMOTION_NOTIFIER_ENABLED=false
PROMOTION_NOTIFIER_ENDPOINT=/product-analysis/wishlist-promotions/run
PROMOTION_NOTIFIER_INTERVAL_MINUTES=60
PROMOTION_NOTIFIER_DRY_RUN=false
